{
  "name": "sf-log-mcp",
  "version": "0.1.0",
  "description": "MCP server that fetches, manages, and AI-analyzes Salesforce debug logs",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sf-log-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "salesforce",
    "apex",
    "debug-log",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "tooling-api"
  ],
  "author": "Likhit Kumar VP",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@salesforce/core": "^8.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
